# Copy sections into the right app env files as needed (defaults match local dev).

# --- Services (optional root `.env` if you inject env into Node processes) ---
ORCHESTRATOR_URL=http://localhost:4100
REALTIME_URL=ws://localhost:4102
REALTIME_HTTP_URL=http://localhost:4102
BROWSER_OPERATOR_URL=http://localhost:4101
SKILLS_REGISTRY_URL=http://localhost:4103
PORT=4100

# Orchestrator: Postgres persistence (unset = JSON file under services/orchestrator/.data/)
# After Postgres is up: npm run migrate:deploy -w @manus-plus/orchestrator
DATABASE_URL=postgresql://manus:manus@localhost:5432/manus

# Optional (Postgres): on startup, delete completed/failed/cancelled runs older than N days
# ORCHESTRATOR_RETENTION_DAYS=90

# --- Next.js: `apps/web/.env.local` ---
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4100
NEXT_PUBLIC_BROWSER_OPERATOR_URL=http://localhost:4101
NEXT_PUBLIC_REALTIME_URL=ws://localhost:4102
NEXT_PUBLIC_SKILLS_REGISTRY_URL=http://localhost:4103

# --- Expo: `apps/mobile/.env` ---
EXPO_PUBLIC_ORCHESTRATOR_URL=http://localhost:4100
EXPO_PUBLIC_REALTIME_URL=ws://localhost:4102

# --- Electron desktop: full product UI (start `npm run dev:apis` + `npm run dev:web` first) ---
MANUS_PLUS_WEB_URL=http://localhost:3000
